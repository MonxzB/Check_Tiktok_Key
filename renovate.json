{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "schedule": ["before 4am on Monday"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false,
      "labels": ["dependencies"]
    },
    {
      "matchPackageNames": ["react", "react-dom"],
      "groupName": "React"
    },
    {
      "matchPackageNames": ["@supabase/supabase-js"],
      "groupName": "Supabase",
      "automerge": false
    },
    {
      "matchPackageNames": ["recharts"],
      "automerge": false,
      "labels": ["dependencies", "breaking-change-risk"]
    }
  ]
}
