# Tạo file này bằng cách copy từ .env.example rồi điền giá trị thực
# cp .env.example .env.local

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Sentry (Task 3.2 — optional) ──────────────────────────────
# Cách nhanh nhất: vercel.com/integrations/sentry (tự inject DSN)
# Hoặc tạo thủ công: sentry.io → Project → Client Keys → DSN
VITE_SENTRY_DSN=

# ── Vercel auto-injected (KHÔNG cần set thủ công) ─────────────
# VITE_VERCEL_GIT_COMMIT_SHA  ← Vercel tự inject khi deploy
# VITE_VERCEL_ENV             ← 'production' | 'preview' | 'development'
