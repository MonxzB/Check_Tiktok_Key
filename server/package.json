  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "4.22.1",
    "node-fetch": "3.3.2"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.19.17",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
